<script>
document.addEventListener('DOMContentLoaded', () => {
    const input = document.querySelector('.product-form__quantity .quantity__input');

    {%- unless product.tags contains 'sample-packs' -%}
      if (input) {
        input.min = 12;
        input.value = 12;
      }
    {%- endunless -%}

    const updateTotalPrice = () => {
        // When Bold qty-break data is loaded, the qb-grid script owns the total:
        // it picks the tier from (page qty + qty already in cart), matching what
        // Bold actually charges on the cart line. Running the naive qty x price
        // math here would overwrite that with the wrong number.
        if (window.BOLDCUSTOM && window.BOLDCUSTOM.qbData && typeof window.BOLDCUSTOM.qbRecalcTotal === 'function') {
            window.BOLDCUSTOM.qbRecalcTotal();
            return;
        }

        const qtyInput = document.querySelector('.product-form__quantity .quantity__input');
        const priceEl = document.querySelector('.ui-price-regular .price-item--regular');
        const totalEl = document.querySelector('.sub-total-price-value');
        if (!qtyInput || !priceEl || !totalEl) return;

        const price = parseFloat(priceEl.innerText.replace(/[^0-9.]/g, '')) || 0;
        const quantity = parseInt(qtyInput.value) || 0;

        totalEl.innerText = "$" + (quantity * price).toFixed(2) + " USD";
    };

    updateTotalPrice();

    if (input) {
        input.addEventListener('input', updateTotalPrice);
        input.addEventListener('change', updateTotalPrice);

        const form = input.closest('form');
        if (form) {
            form.addEventListener('qty_change', updateTotalPrice);
        }
    }

    if (typeof subscribe === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
        // Programmatic quantity resets (setQuantityBoundries) publish quantityUpdate.
        if (PUB_SUB_EVENTS.quantityUpdate) {
            subscribe(PUB_SUB_EVENTS.quantityUpdate, updateTotalPrice);
        }
        // Selecting a different option re-renders the price (and the total element)
        // and publishes variantChange afterwards — recompute with the new price then.
        if (PUB_SUB_EVENTS.variantChange) {
            subscribe(PUB_SUB_EVENTS.variantChange, updateTotalPrice);
        }
    }
});
</script>