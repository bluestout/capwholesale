{% comment %}
  Renders product buy-buttons.
  Accepts:
  - product: {Object} product object.
  - block: {Object} passing the block information.
  - product_form_id: {String} product form id.
  - section_id: {String} id of section to which this snippet belongs.
  - show_pickup_availability: {Boolean} for the pickup availability. If true the pickup availability is rendered, false - not rendered (optional).

  Usage:
  {% render 'buy-buttons', block: block, product: product, product_form_id: product_form_id, section_id: section.id, show_pickup_availability: true %}
{% endcomment %}
<div {{ block.shopify_attributes }}>
  {%- if product != blank -%}
    {%- liquid
      assign gift_card_recipient_feature_active = false
      if block.settings.show_gift_card_recipient and product.gift_card?
        assign gift_card_recipient_feature_active = true
      endif

      assign show_dynamic_checkout = false
      if block.settings.show_dynamic_checkout and gift_card_recipient_feature_active == false
        assign show_dynamic_checkout = true
      endif
    -%}

    {%- assign blocked_single_pieces = 'Richardson,Decky,Zapped,Mega' | downcase | split: ',' -%}

    {%- liquid
      assign blocked_single_product = true
      assign downcased_vendor = product.vendor | downcase
      for blocked_single_piece in blocked_single_pieces
        if downcased_vendor contains blocked_single_piece
          assign blocked_single_product = false
          break
        endif
      endfor
    -%}

    {%- if block.settings.buy_btn_text != blank and blocked_single_product -%}
      <div class="lower-price-product-cart">
        <button
          id="ProductSubmitButton-{{ section_id }}"
          type="button"
          name="add"
          class="buy-lower-price-btn {% if show_dynamic_checkout %}button--secondary{% else %}button--primary{% endif %} buy-lower-price-btn--inactive"
          aria-label="Buy a single piece at promotional price"
        >
          {%- assign promo_price = product.selected_or_first_available_variant.price | money_with_currency %}
          {{ block.settings.buy_btn_text | replace: '__PRICE__', promo_price }}
        </button>
        <p class="buy-lower-price-hint" aria-live="polite">Select a quantity of 1–3 to unlock this price</p>
      </div>
    {%- endif -%}

    <product-form
      class="product-form"
      data-hide-errors="{{ gift_card_recipient_feature_active }}"
      data-section-id="{{ section.id }}"
    >
      <div class="product-form__error-message-wrapper" role="alert" hidden>
        <span class="svg-wrapper">
          {{- 'icon-error.svg' | inline_asset_content -}}
        </span>
        <span class="product-form__error-message"></span>
      </div>

      {%- form 'product',
        product,
        id: product_form_id,
        class: 'form',
        novalidate: 'novalidate',
        data-type: 'add-to-cart-form'
      -%}
        <input
          type="hidden"
          name="id"
          value="{{ product.selected_or_first_available_variant.id }}"
          {% if product.selected_or_first_available_variant.available == false
            or quantity_rule_soldout
            or product.selected_or_first_available_variant == null
          %}
            disabled
          {% endif %}
          class="product-variant-id"
        >

        <input type="hidden" name="properties[SKU]" value="{{ product.selected_or_first_available_variant.sku }}">
        <input type="hidden" name="properties[Brand]" value="{{ product.vendor }}">

        {%- if gift_card_recipient_feature_active -%}
          {%- render 'gift-card-recipient-form', product: product, form: form, section: section -%}
        {%- endif -%}

        <div class="product-form__buttons ui-add-cart-button">
          {%- liquid
            assign check_against_inventory = true
            if product.selected_or_first_available_variant.inventory_management != 'shopify' or product.selected_or_first_available_variant.inventory_policy == 'continue'
              assign check_against_inventory = false
            endif
            if product.selected_or_first_available_variant.quantity_rule.min > product.selected_or_first_available_variant.inventory_quantity and check_against_inventory
              assign quantity_rule_soldout = true
            endif
          -%}
          <button
            id="ProductSubmitButton-{{ section_id }}"
            type="submit"
            name="add"
            class="product-form__submit button button--full-width {% if show_dynamic_checkout %}button--secondary{% else %}button--primary{% endif %}"
            {% if product.selected_or_first_available_variant.available == false
              or quantity_rule_soldout
              or product.selected_or_first_available_variant == null
            %}
              disabled
            {% endif %}
          >
            <span>
              {%- if product.selected_or_first_available_variant == null -%}
                {{ 'products.product.unavailable' | t }}
              {%- elsif product.selected_or_first_available_variant.available == false or quantity_rule_soldout -%}
                {{ 'products.product.sold_out' | t }}
              {%- else -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- endif -%}
            </span>
            {%- render 'loading-spinner' -%}
          </button>
          {%- if show_dynamic_checkout -%}
            {{ form | payment_button }}
          {%- endif -%}
        </div>
      {%- endform -%}
    </product-form>

  {%- else -%}
    <div class="product-form">
      <div class="product-form__buttons form">
        <button
          type="submit"
          name="add"
          class="product-form__submit button button--full-width button--primary"
          disabled
        >
          {{ 'products.product.sold_out' | t }}
        </button>
      </div>
    </div>
  {%- endif -%}

  {%- if show_pickup_availability -%}
    {{ 'component-pickup-availability.css' | asset_url | stylesheet_tag }}

    {%- assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities
      | where: 'pick_up_enabled', true
    -%}

    <pickup-availability
      class="product__pickup-availabilities quick-add-hidden"
      {% if product.selected_or_first_available_variant.available and pick_up_availabilities.size > 0 %}
        available
      {% endif %}
      data-root-url="{{ routes.root_url }}"
      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
      data-has-only-default-variant="{{ product.has_only_default_variant }}"
      data-product-page-color-scheme="gradient color-{{ section.settings.color_scheme }}"
    >
      <template>
        <pickup-availability-preview class="pickup-availability-preview">
          <span class="svg-wrapper">
            {{- 'icon-unavailable.svg' | inline_asset_content -}}
          </span>
          <div class="pickup-availability-info">
            <p class="caption-large">{{ 'products.product.pickup_availability.unavailable' | t }}</p>
            <button class="pickup-availability-button link link--text underlined-link">
              {{ 'products.product.pickup_availability.refresh' | t }}
            </button>
          </div>
        </pickup-availability-preview>
      </template>
    </pickup-availability>

    <script src="{{ 'pickup-availability.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
</div>

<style>
  .buy-lower-price-btn {
    padding: 12px 35px;
    font-size: 15px;
    font-family: Inter, sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    line-height: 25.5px;
    word-wrap: break-word;
    border: 2px solid transparent;
    width: 100%;
    cursor: pointer;
    border-radius: 3px;
    text-align: center;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: background-color 0.2s ease, color 0.2s ease, opacity 0.2s ease;
  }

  .buy-lower-price-btn:not(.buy-lower-price-btn--inactive) {
    background-color: #f3f3f3;
    color: #ee0000;
    border-color: #ee0000;
  }

  .buy-lower-price-btn:not(.buy-lower-price-btn--inactive):hover {
    background-color: #ee0000;
    color: #ffffff;
  }

  .buy-lower-price-btn--inactive {
    background-color: #e8e8e8;
    color: #aaaaaa;
    border-color: #cccccc;
    cursor: not-allowed;
    opacity: 0.7;
  }

  .lower-price-product-cart {
    margin-bottom: 10px;
  }

  .buy-lower-price-hint {
    font-size: 12px;
    color: #888888;
    text-align: center;
    margin: 4px 0 0 !important;
    padding: 0;
    min-height: 18px;
    line-height: 18px;
    display: block !important;
    visibility: visible !important;
    transition: color 0.2s ease;
  }

  .buy-lower-price-hint.hint--ok {
    color: #2a7a2a;
  }

  .buy-lower-price-hint.hint--warn {
    color: #cc4400;
  }
</style>

<script>
  (function () {
    function getQuantityInput() {
      return document.querySelector('.product .quantity input[name="quantity"]');
    }
    function getPromoButton() {
      return document.querySelector('.buy-lower-price-btn');
    }
    function getHint() {
      return document.querySelector('.buy-lower-price-hint');
    }
    function getMainButton() {
      return document.querySelector('.product-form__submit');
    }

    async function getCartQuantityForVariant(variantId) {
      try {
        const res = await fetch('/cart.js');
        const cart = await res.json();
        return cart.items.filter((i) => i.variant_id === variantId).reduce((sum, i) => sum + i.quantity, 0);
      } catch (_) {
        return 0;
      }
    }

    async function updateButtonState() {
      const promoBtn = getPromoButton();
      const mainBtn = getMainButton();
      const hint = getHint();
      const input = getQuantityInput();
      if (!input) return;

      const qty = parseInt(input.value, 10);

      const variantInput = document.querySelector('.product-variant-id');
      let cartQty = 0;
      if (variantInput && variantInput.value) {
        cartQty = await getCartQuantityForVariant(parseInt(variantInput.value, 10));
      }

      const cartMaxed = cartQty >= 3;

      if (cartMaxed) {
        if (promoBtn) {
          promoBtn.setAttribute('disabled', 'true');
          promoBtn.classList.add('buy-lower-price-btn--inactive');
        }
        if (mainBtn) mainBtn.removeAttribute('disabled');
        if (hint) {
          hint.textContent = "You've already added 3 single pieces of this style.";
          hint.className = 'buy-lower-price-hint hint--warn';
        }
      } else if (qty >= 1 && qty <= 3) {
        if (promoBtn) {
          promoBtn.removeAttribute('disabled');
          promoBtn.classList.remove('buy-lower-price-btn--inactive');
        }
        if (mainBtn) mainBtn.setAttribute('disabled', 'true');
        if (hint) {
          const remaining = 3 - cartQty;
          hint.textContent =
            cartQty > 0
              ? 'You can still add ' + remaining + ' more single piece' + (remaining > 1 ? 's' : '') + ' at this price.'
              : 'Max 3 single pieces per style at this price.';
          hint.className = 'buy-lower-price-hint hint--ok';
        }
      } else if (qty >= 12) {
        if (promoBtn) {
          promoBtn.setAttribute('disabled', 'true');
          promoBtn.classList.add('buy-lower-price-btn--inactive');
        }
        if (mainBtn) mainBtn.removeAttribute('disabled');
        if (hint) {
          hint.textContent = 'Buying in bulk? Use Add to Cart below.';
          hint.className = 'buy-lower-price-hint';
        }
      } else {
        if (promoBtn) {
          promoBtn.setAttribute('disabled', 'true');
          promoBtn.classList.add('buy-lower-price-btn--inactive');
        }
        if (mainBtn) mainBtn.setAttribute('disabled', 'true');
        if (hint) {
          hint.textContent = 'Enter 1–3 for single-piece price, or 12+ to add to cart.';
          hint.className = 'buy-lower-price-hint hint--warn';
        }
      }
    }

    function observeQuantityInput() {
      const input = getQuantityInput();
      if (!input) return;

      input.addEventListener('invalid', (e) => e.preventDefault());
      input.addEventListener('input', updateButtonState);
      input.addEventListener('change', updateButtonState);

      new MutationObserver(updateButtonState).observe(input, { attributes: true, attributeFilter: ['value'] });

      let lastQty = input.value;
      setInterval(() => {
        if (input.value !== lastQty) {
          lastQty = input.value;
          updateButtonState();
        }
      }, 150);
    }

    function observeVariantInput() {
      const variantInput = document.querySelector('.product-variant-id');
      if (!variantInput) return;

      new MutationObserver(updateButtonState).observe(variantInput, { attributes: true, attributeFilter: ['value'] });

      let lastVariant = variantInput.value;
      setInterval(() => {
        if (variantInput.value !== lastVariant) {
          lastVariant = variantInput.value;
          updateButtonState();
        }
      }, 300);

      document.addEventListener('variant:change', updateButtonState);
      document.addEventListener('variantChange', updateButtonState);
    }

    document.addEventListener('DOMContentLoaded', function () {
      updateButtonState();
      observeQuantityInput();
      observeVariantInput();

      document.addEventListener('cart:refresh', updateButtonState);
      document.addEventListener('cart-update', updateButtonState);
      document.addEventListener('cart:updated', updateButtonState);
    });
  })();
</script>
