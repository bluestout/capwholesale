<script>
  window.BOLD = window.BOLD || {};
  window.BOLDCUSTOM = window.BOLDCUSTOM || {};
  window.BOLD.pre = window.BOLD.pre || {};
  window.BOLD.pre.config = window.BOLD.pre.config || {};

  window.BOLDCUSTOM.rules = window.BOLDCUSTOM.rules || {};
  window.BOLDCUSTOM.customerTags = {{ customer.tags | default: [] | json }};
  window.BOLDCUSTOM.product = {{ product | json }};
  window.BOLDCUSTOM.cartvariants = {{ cart.items | map: 'variant' | map: 'id' | json }}

  // Loop guards
  let _restoring = false;
  let _restoreCount = 0;
  const MAX_RESTORES = 30;

  function getQBData() {
    const mainProduct = window.BOLDCUSTOM.product;
    if (!mainProduct) { return; }

    fetch(`https://api.boldcommerce.com/go_pre/pricerules/stjzta-ux.myshopify.com/rulesets?products=${mainProduct.id}&customer_tags=${window.BOLDCUSTOM.customerTags?.join(',') || ''}`)
      .then(function (resp) { return resp.json(); })
      .then(function (rules) {
        // === GROUP RULESETS BY TIER LADDER SIGNATURE ===
        //
        // Bold's API returns multiple rulesets for one product. Different variants on a single
        // product can have DIFFERENT tier ladders (e.g. plain colors at one price, patterned
        // colors at another). The API does not tell us cleanly which ruleset belongs to which
        // variant.
        //
        // Strategy:
        // 1. For each ruleset, extract its full qty-break ladder
        // 2. Group rulesets that share the same ladder signature
        // 3. For each variant, pick the ladder whose qty-12 price matches the variant's
        //    own price. (We've aligned base price = qty-12 price via Matrixify.)
        // 4. Outlier ladders (appearing in only 1 ruleset out of many) are excluded — these
        //    are typically "poisoned" multi-product rulesets contaminating the response.

        const ladders = {}; // signature -> { qbLevels, count, qty12Price }

        for (let rs = 0; rs < (rules.rulesets || []).length; rs++) {
          const ruleset = rules.rulesets[rs];
          const breaks = [];
          for (let r = 0; r < (ruleset.rules || []).length; r++) {
            const rule = ruleset.rules[r];
            if (rule.type !== 'DISPLAY') continue;
            for (let a = 0; a < (rule.actions || []).length; a++) {
              const action = rule.actions[a];
              if (action.type !== 'DISPLAY_QTY_BREAK') continue;
              breaks.push({
                qty: action.qty,
                price: action.price != null ? action.price : null,
                saved: action.saved != null ? action.saved : null,
                percent: action.percent != null ? action.percent : null
              });
            }
          }
          if (breaks.length === 0) continue;

          breaks.sort(function (a, b) { return a.qty - b.qty; });
          const signature = breaks.map(function (b) {
            return b.qty + ':' + (b.price != null ? b.price : '') + ':' + (b.saved != null ? b.saved : '') + ':' + (b.percent != null ? b.percent : '');
          }).join('|');

          if (!ladders[signature]) {
            const q12 = breaks.find(function (b) { return b.qty === 12; });
            ladders[signature] = {
              qbLevels: breaks,
              count: 0,
              qty12Price: q12 ? q12.price : null
            };
          }
          ladders[signature].count++;
        }

        // Identify trustworthy ladders: those backed by more than 1 ruleset, OR the only
        // ladder available when very few rulesets came back.
        const ladderArr = Object.values(ladders);
        const totalRulesets = (rules.rulesets || []).length;
        const supportThreshold = totalRulesets > 4 ? 2 : 1;
        const trustedLadders = ladderArr.filter(function (l) { return l.count >= supportThreshold; });

        // If filtering threw everything away (e.g. a product where each variant truly has
        // a unique ladder backed by just 1 ruleset), fall back to keeping all of them.
        const finalLadders = trustedLadders.length > 0 ? trustedLadders : ladderArr;

        window.BOLDCUSTOM.ladders = finalLadders;

        buildQBGrids(mainProduct, finalLadders);
        renderAll();
        startGuardian();
      })
      .catch(function (err) { console.error('[qb-grid] fetch failed:', err); });
  }

  // For a given variant, pick the right tier ladder.
  // Match by qty-12 price == variant.price (since we've aligned base = qty12).
  // Fall back to closest match if no exact match.
  function pickLadderForVariant(variant, ladders) {
    if (!ladders || ladders.length === 0) return null;
    if (ladders.length === 1) return ladders[0];

    // Exact match on qty-12 price
    const exact = ladders.find(function (l) {
      return l.qty12Price != null && Math.abs(l.qty12Price - variant.price) < 0.5;
    });
    if (exact) return exact;

    // Otherwise pick the ladder whose qty-12 price is closest to (but not greater than) variant.price
    let best = null;
    let bestDiff = Infinity;
    ladders.forEach(function (l) {
      if (l.qty12Price == null) return;
      const diff = Math.abs(l.qty12Price - variant.price);
      if (diff < bestDiff) {
        bestDiff = diff;
        best = l;
      }
    });
    return best || ladders[0];
  }

  function buildQBGrids(product, ladders) {
    const qbData = {};
    const qbGrids = {};

    for (let v = 0; v < product.variants.length; v++) {
      const variant = product.variants[v];
      const ladder = pickLadderForVariant(variant, ladders);
      if (!ladder) { continue; }

      const variantBreaks = [];
      for (let q = 0; q < ladder.qbLevels.length; q++) {
        const qbRule = ladder.qbLevels[q];
        let price = variant.price;
        if (qbRule.saved) {
          price = Math.max(price - qbRule.saved, 0);
        } else if (qbRule.percent) {
          price = Math.round(price - (price * (qbRule.percent / 100)));
        } else if (qbRule.price != null) {
          price = qbRule.price;
        }
        variantBreaks.push({ qty: qbRule.qty, price: price });
      }

      qbData[variant.id] = variantBreaks;

      let gridHTML = '';
      for (let d = 0; d < variantBreaks.length; d++) {
        const rowData = variantBreaks[d];
        gridHTML += `<tr><td>${rowData.qty}</td><td>${(rowData.price * 0.01).toLocaleString(undefined, { style: 'currency', currency: {{ shop.currency | json }} })}</td></tr>`;
      }

      qbGrids[variant.id] = `<table class="shappify_qb_grid" data-source="qb-grid-snippet">
        <thead><tr><th>Qty</th><th>Price</th></tr></thead>
        <tbody>
          <tr><td>1</td><td>${(variant.price * 0.01).toLocaleString(undefined, { style: 'currency', currency: {{ shop.currency | json }} })}</td></tr>
          ${gridHTML}
        </tbody>
      </table>`;
    }

    window.BOLDCUSTOM.qbData = qbData;
    window.BOLDCUSTOM.qbGrids = qbGrids;
  }

  function recalcTotalPrice(form) {
    if (!form) { return; }
    const variantId = form.id?.value;
    const qty = parseInt(form.quantity?.value);
    const totalEl = document.querySelector('.sub-total-price-value');
    if (!variantId || !qty || !totalEl) { return; }

    const variantData = window.BOLDCUSTOM.product?.variants?.find(v => String(v.id) === String(variantId));
    const qbData = window.BOLDCUSTOM.qbData?.[variantId];

    let bestRow = null;
    if (qbData) {
      for (let i = 0; i < qbData.length; i++) {
        if (qbData[i].qty <= qty) bestRow = qbData[i];
        else break;
      }
    }
    const bestPrice = bestRow?.price ?? variantData?.price ?? 0;
    totalEl.innerText = (bestPrice * qty * 0.01).toLocaleString(undefined, {
      style: 'currency',
      currency: {{ shop.currency | json }}
    });
  }

  function rebuildRadios(gridEl) {
    const radiosContainer = document.querySelector('.es-quantity-radios');
    if (!radiosContainer) return;

    const table = gridEl.querySelector('table[data-source="qb-grid-snippet"]');
    if (!table) return;

    const existingBody = radiosContainer.querySelector('.es-quantity-radios__body');

    const body = document.createElement('div');
    body.className = 'es-quantity-radios__body';

    const trs = table.querySelectorAll('tbody tr');
    trs.forEach((tr, index) => {
      const cells = tr.querySelectorAll('td');
      const qty = cells[0]?.textContent.trim();
      const price = cells[1]?.textContent.trim();
      if (!qty) return;

      const label = document.createElement('label');
      const input = document.createElement('input');
      const customInput = document.createElement('span');
      const spanQty = document.createElement('span');
      const spanPrice = document.createElement('span');

      spanQty.className = 'es-quantity-radios__pty';
      spanPrice.className = 'es-quantity-radios__price';
      customInput.className = 'es-quantity-radios__custom-input';

      input.type = 'radio';
      input.name = 'ESQuantityRadios';
      input.value = qty;
      label.setAttribute('data-quantity', qty);

      if (index === 1) input.setAttribute('checked', 'checked');

      spanQty.textContent = qty + '+';
      spanPrice.textContent = price;

      label.appendChild(input);
      label.appendChild(customInput);
      label.appendChild(spanQty);
      label.appendChild(spanPrice);
      body.appendChild(label);

      input.addEventListener('change', function () {
        const qtyInput = document.querySelector('.product .product-form__quantity .quantity__input');
        if (qtyInput) {
          qtyInput.value = this.value;
          qtyInput.form?.dispatchEvent(new CustomEvent('qty_change', { bubbles: true }));
        }
      });
    });

    const newSig = body.textContent;
    const oldSig = existingBody ? existingBody.textContent : '';
    if (newSig === oldSig) return;

    if (existingBody) existingBody.parentElement.removeChild(existingBody);
    radiosContainer.appendChild(body);
  }

  function renderInto(form) {
    let gridEl = form.querySelector('.bold_qb_grid_custom');
    if (!gridEl) {
      gridEl = document.createElement('div');
      gridEl.className = 'bold_qb_grid_custom';
      gridEl.id = 'bold_qb_grid';
      form.prepend(gridEl);
    }

    const correctHTML = window.BOLDCUSTOM?.qbGrids?.[form.id?.value] || '';
    if (correctHTML && gridEl.innerHTML !== correctHTML) {
      gridEl.innerHTML = correctHTML;
    }
    rebuildRadios(gridEl);
  }

  function renderAll() {
    if (_restoring) return;
    if (_restoreCount > MAX_RESTORES) return;
    _restoring = true;
    try {
      const mainProduct = window.BOLDCUSTOM.product;
      if (!mainProduct) return;
      for (let f = 0; f < document.forms.length; f++) {
        const form = document.forms[f];
        if (!(form.action.includes('cart/add'))) continue;

        renderInto(form);

        if (!form._qbBound) {
          form._qbBound = true;
          form.addEventListener('change', function (evt) {
            const isVariantChange = evt.target && (
              evt.target.name === 'id' ||
              evt.target.closest?.('[name="id"]') ||
              (!evt.target.name?.includes('quantity') && !evt.target.name?.includes('qty'))
            );
            renderAll();
            if (isVariantChange) {
              requestAnimationFrame(() => requestAnimationFrame(() => recalcTotalPrice(form)));
            }
          });
          form.addEventListener('qty_change', function (e) { recalcTotalPrice(e.target); });
        }
        recalcTotalPrice(form);
      }
    } finally {
      setTimeout(function () { _restoring = false; }, 0);
    }
  }

  function needsRestore() {
    const grids = document.querySelectorAll('#bold_qb_grid, .bold_qb_grid_custom');
    if (grids.length === 0) return true;
    let ok = true;
    grids.forEach(function (grid) {
      const table = grid.querySelector('table');
      if (!table || table.getAttribute('data-source') !== 'qb-grid-snippet') ok = false;
    });
    return !ok;
  }

  let guardianStarted = false;
  function startGuardian() {
    if (guardianStarted) return;
    guardianStarted = true;

    const observer = new MutationObserver(function () {
      if (_restoring) return;
      if (!needsRestore()) return;
      _restoreCount++;
      renderAll();
    });
    observer.observe(document.body, { childList: true, subtree: true });

    let ticks = 0;
    const interval = setInterval(function () {
      ticks++;
      if (!_restoring && needsRestore()) {
        _restoreCount++;
        renderAll();
      }
      if (ticks > 20 || _restoreCount > MAX_RESTORES) clearInterval(interval);
    }, 500);
  }

  window.addEventListener('load', getQBData);
</script>

<style>
  table.shappify_qb_grid { width: auto; }
  div.bold_qb_grid { width: 100%; }
  table.shappify_qb_grid {
    width: 100%;
    font-size: 12px;
  }
  table.shappify_qb_grid thead,
  table.shappify_qb_grid thead tr,
  table.shappify_qb_grid thead th,
  table.shappify_qb_grid thead td {
    background: #d6d6d6;
    color: #000000;
    font-weight: bold;
  }
  table.shappify_qb_grid tbody tr:nth-child(odd) { background-color: #ffffff; }
  table.shappify_qb_grid tbody tr:nth-child(even) { background-color: #efefef; }
  table.shappify_qb_grid tbody { color: #000000; }
  table.shappify_qb_grid,
  table.shappify_qb_grid th,
  table.shappify_qb_grid td {
    text-align: left;
    padding: 5px;
    border: 1px solid #cccccc;
    border-collapse: collapse;
  }
  table.shappify_qb_grid {
    margin: 0px;
    margin-bottom: 1.5rem;
  }
</style>
