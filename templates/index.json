    "es_testimonial_xNiLtf": {
      "type": "es-testimonial",
      "blocks": {
        "review_xxMRxP": {
          "type": "review",
          "settings": {
            "title": "Amazing Hats!",
            "image": "shopify://shop_images/Stars.svg",
            "text": "<p>We designed some hats to give away to patients and promote the business.  The patients have loved them!  Thanks to Lisette in customer service who has made the process easy! Great Company and excellent service!</p>",
            "created_at": "Tue, Sep 01 2020",
            "name": "Julie"
          }
        },
        "review_LNLbd3": {
          "type": "review",
          "settings": {
            "title": "Perfect Hats!",
            "image": "shopify://shop_images/Stars.svg",
            "text": "<p>Our hats are awesome! Customers and employees alike are always asking for new ones!</p>",
            "created_at": "Mon, Aug 31 2020",
            "name": "Sarah M Dymond"
          }
        },
        "review_h8GNw6": {
          "type": "review",
          "settings": {
            "title": "Thanks Robin! Great Caps/Great Service",
